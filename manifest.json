{
  "manifest_version": 3,
  "name": "GHL Prospector \u2014 Google Maps Lead Scraper",
  "description": "Scrape business leads from Google Maps. Find no-website businesses, export to CSV for GoHighLevel. Free & unlimited.",
  "version": "1.2.0",
  "author": "Ro",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://www.google.co.uk/maps/*",
        "https://www.google.ca/maps/*",
        "https://www.google.com.au/maps/*",
        "https://www.google.de/maps/*",
        "https://www.google.fr/maps/*",
        "https://www.google.es/maps/*",
        "https://www.google.it/maps/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}